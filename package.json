{
  "name": "axutils",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "biome:check": "biome check .",
    "build": "corepack pnpm -r build",
    "changeset": "changeset",
    "check": "biome check . && corepack pnpm -r typecheck && corepack pnpm -r test && corepack pnpm -r build && corepack pnpm --filter @axutils/common test:dist && corepack pnpm --filter @axutils/common publint",
    "format": "biome format --write .",
    "lint": "biome check .",
    "release": "changeset publish",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "version-packages": "changeset version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crx-96/axutils.git"
  },
  "bugs": {
    "url": "https://github.com/crx-96/axutils/issues"
  },
  "homepage": "https://github.com/crx-96/axutils#readme",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "2.31.0",
    "@types/node": "24.12.4",
    "publint": "0.3.21",
    "typescript": "7.0.1-rc",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}

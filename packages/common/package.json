{
  "name": "@axutils/common",
  "version": "0.0.0",
  "description": "axutils 的公共工具子包",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.cjs",
  "jsdelivr": "./dist/index.umd.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./check/type": {
      "import": {
        "types": "./dist/check/type.d.ts",
        "default": "./dist/check/type.js"
      },
      "require": {
        "types": "./dist/check/type.d.cts",
        "default": "./dist/check/type.cjs"
      }
    },
    "./check/reg": {
      "import": {
        "types": "./dist/check/reg.d.ts",
        "default": "./dist/check/reg.js"
      },
      "require": {
        "types": "./dist/check/reg.d.cts",
        "default": "./dist/check/reg.cjs"
      }
    },
    "./check/platform": {
      "import": {
        "types": "./dist/check/platform.d.ts",
        "default": "./dist/check/platform.js"
      },
      "require": {
        "types": "./dist/check/platform.d.cts",
        "default": "./dist/check/platform.cjs"
      }
    },
    "./object/json": {
      "import": {
        "types": "./dist/object/json.d.ts",
        "default": "./dist/object/json.js"
      },
      "require": {
        "types": "./dist/object/json.d.cts",
        "default": "./dist/object/json.cjs"
      }
    },
    "./object/url": {
      "import": {
        "types": "./dist/object/url.d.ts",
        "default": "./dist/object/url.js"
      },
      "require": {
        "types": "./dist/object/url.d.cts",
        "default": "./dist/object/url.cjs"
      }
    },
    "./crypto/md5": {
      "import": {
        "types": "./dist/crypto/md5.d.ts",
        "default": "./dist/crypto/md5.js"
      },
      "require": {
        "types": "./dist/crypto/md5.d.cts",
        "default": "./dist/crypto/md5.cjs"
      }
    },
    "./crypto/convert": {
      "import": {
        "types": "./dist/crypto/convert.d.ts",
        "default": "./dist/crypto/convert.js"
      },
      "require": {
        "types": "./dist/crypto/convert.d.cts",
        "default": "./dist/crypto/convert.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.js"
      },
      "require": {
        "types": "./dist/node/index.d.cts",
        "default": "./dist/node/index.cjs"
      }
    },
    "./node/crypto/md5": {
      "import": {
        "types": "./dist/node/crypto/md5.d.ts",
        "default": "./dist/node/crypto/md5.js"
      },
      "require": {
        "types": "./dist/node/crypto/md5.d.cts",
        "default": "./dist/node/crypto/md5.cjs"
      }
    },
    "./node/crypto/convert": {
      "import": {
        "types": "./dist/node/crypto/convert.d.ts",
        "default": "./dist/node/crypto/convert.js"
      },
      "require": {
        "types": "./dist/node/crypto/convert.d.cts",
        "default": "./dist/node/crypto/convert.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "safe-stable-stringify": "^2.4.0",
    "spark-md5": "^3.0.2"
  },
  "peerDependenciesMeta": {
    "safe-stable-stringify": {
      "optional": true
    },
    "spark-md5": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crx-96/axutils.git",
    "directory": "packages/common"
  },
  "bugs": {
    "url": "https://github.com/crx-96/axutils/issues"
  },
  "homepage": "https://github.com/crx-96/axutils/tree/main/packages/common#readme",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "publint": "publint run . --pack npm",
    "test": "vitest run",
    "test:dist": "node ./scripts/build.mjs && node ./scripts/smoke-esm.mjs && node ./scripts/smoke-cjs.cjs && node ./scripts/smoke-umd.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "spark-md5": "^3.0.2"
  }
}
